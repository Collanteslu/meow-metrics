# Database
DATABASE_URL=postgresql://user:password@localhost:5432/meow_metrics

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Server
PORT=3001
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Email Configuration
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@meow-metrics.com
NODE_MAILER_HOST=smtp.gmail.com
NODE_MAILER_PORT=587
NODE_MAILER_USER=your_email@gmail.com
NODE_MAILER_PASS=your_app_password

# App URL
APP_URL=http://localhost:3000
